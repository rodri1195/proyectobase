{
  "C_Cpp.intelliSenseEngine": "default",
  "idf.openOcdConfigs": [
    "board/esp32c3-builtin.cfg"
  ],
  "idf.port": "/dev/ttyACM0",
  "idf.currentSetup": "/home/osboxes/.espressif/v6.0/esp-idf",
  "idf.customExtraVars": {
    "IDF_TARGET": "esp32c3",
    "OPENOCD_USB_ADAPTER_LOCATION": "1-2"
  },
  "idf.openOcdLaunchArgs": [
    "-f",
    "board/esp32c3-builtin.cfg"
  ],
  "idf.svdFilePath": "${workspaceFolder}/.vscode/esp32c3.svd",
  "idf.flashType": "JTAG",
  "debug.allowBreakpointsEverywhere": true,
  "files.associations": {
    "*.S": "riscv",
    "*.s": "riscv"
  },
  "editor.formatOnSave": true,
  "workbench.colorCustomizations": {
    "activityBar.background": "#610606",
    "titleBar.activeBackground": "#F89C9C",
    "titleBar.activeForeground": "#3A0404",
    "titleBar.inactiveBackground": "#610606",
    "titleBar.inactiveForeground": "#3A0404",
    "statusBar.background": "#740808",
    "statusBar.foreground": "#FFFAFA",
    "statusBar.debuggingBackground": "#740808",
    "statusBar.debuggingForeground": "#FFFAFA",
    "statusBar.noFolderBackground": "#740808",
    "statusBar.noFolderForeground": "#FFFAFA"
  }
}